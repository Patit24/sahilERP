VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_ENABLE_SUPABASE_AUTH=false
VITE_ENABLE_REMOTE_STORAGE=false
VITE_DISABLE_LOCAL_CACHE=false

# Never put the Supabase secret/service_role key in this frontend app.
# Keep remote storage disabled until Supabase Auth and company-scoped RLS are configured.
# For production on shared devices, set VITE_DISABLE_LOCAL_CACHE=true after remote storage is working.
